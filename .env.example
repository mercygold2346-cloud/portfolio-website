# =============================================================================
# IMPORTANT: Next.js does NOT read this file.
# Copy what you need into ".env.local" (same folder as package.json),
# then restart: npm run dev
# =============================================================================

# --- Option A (recommended): Resend — no Gmail SMTP, fewer login errors ---
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Optional; default is Resend's test sender (good for testing):
# RESEND_FROM=Portfolio <onboarding@resend.dev>
# Where you receive contact form messages (your Gmail is fine):
CONTACT_TO=you@gmail.com

# --- Option B: Gmail SMTP (App Password, not your normal password) ---
# https://myaccount.google.com/apppasswords
# GMAIL_USER must be the SAME Google account that created the App Password.
GMAIL_USER=you@gmail.com
# 16 characters after spaces removed. If your password contains # wrap the value in quotes:
# GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: receive form mail at a different address than GMAIL_USER
# CONTACT_TO=you@gmail.com

# Shown on the Email card + mailto: (must start with NEXT_PUBLIC_)
NEXT_PUBLIC_CONTACT_EMAIL=you@gmail.com

# Projects section — GitHub profile + per-project repo links
# NEXT_PUBLIC_GITHUB_URL=https://github.com/mercygold2346-cloud
# NEXT_PUBLIC_GITHUB_USERNAME=mercygold2346-cloud
